{
  "platform": "openrouter",
  "name": "OpenRouter",
  "description": "OpenRouter AI模型服务平台",
  "icon": "/assets/aiplatform/openrouter.png",
  "enabled": false,
  "config": {
    "api_key": "",
    "base_url": "https://openrouter.ai/api/v1",
    "timeout": 30,
    "headers": {
      "Content-Type": "application/json"
    }
  },
  "models": [
    {
      "id": "openai/gpt-4-turbo",
      "name": "GPT-4 Turbo",
      "description": "OpenAI的GPT-4 Turbo模型",
      "enabled": true,
      "params": {
        "context_window": 128000,
        "temperature": 0.7,
        "top_p": 0.95,
        "max_tokens": 4096
      },
      "doc_url": "https://openrouter.ai/docs"
    }
  ],
  "auth_method": "api_key",
  "version": "1.0.0"
}