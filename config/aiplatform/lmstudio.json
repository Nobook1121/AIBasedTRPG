{
  "platform": "lmstudio",
  "name": "LMStudio",
  "description": "本地运行的AI模型服务器，兼容OpenAI API",
  "enabled": true,
  "icon": "/assets/aiplatform/lmstudio.png",
  "config": {
    "api_key": "lm-studio",
    "base_url": "http://localhost:1234/v1/chat/completions",
    "timeout": 30
  },
  "models": [
    {
      "id": "local-model",
      "name": "本地模型",
      "description": "LMStudio中运行的本地模型",
      "enabled": true,
      "params": {
        "context_window": 8192,
        "temperature": 0.7,
        "top_p": 0.95,
        "max_tokens": 4096
      }
    }
  ]
}